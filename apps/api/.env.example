# Safe local template. Replace all placeholder values with freshly rotated secrets before use.

NODE_ENV=development
PORT=8080
WEB_ORIGIN=http://localhost:8080

DATABASE_URL=
DIRECT_DATABASE_URL=

ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_HASH=

JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
SESSION_SECRET=replace-me

S3_REGION=eu-west-2
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

RESEND_FROM_EMAIL=noreply@example.com
RESEND_TO_EMAIL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

REDIS_URL=
EMAIL_QUEUE_ENABLED=false

ALLOW_LOCAL_CV_UPLOADS=true
LOCAL_CV_UPLOAD_ROOT=/tmp/vergo-cv-uploads
EXPOSE_DEV_VERIFICATION_LINKS=false

SENTRY_DSN=
LOG_LEVEL=info
MEMORY_LOG_ENABLED=false
MEMORY_LOG_INTERVAL_MS=300000
MEMORY_WARN_RSS_MB=384

SESSION_STORE_SSL_REJECT_UNAUTHORIZED=true
